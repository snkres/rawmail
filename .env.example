# Domain
RAWMAIL_DOMAIN=rawmail.sh
MX_TARGET=mx.rawmail.sh

# URLs — for local dev leave as-is; for production set to your public URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3001   # public URL of the API (for OAuth callbacks)
WEB_URL=http://localhost:3000           # public URL of the web app (for CORS)

# Database / Redis (used inside Docker network; override for local dev)
DATABASE_URL=postgresql://rawmail:rawmail@localhost:5432/rawmail
REDIS_URL=redis://localhost:6379

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BETTER_AUTH_URL}/v1/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session signing — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TEAMS_PRICE_ID=price_...
